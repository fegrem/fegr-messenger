# Fegr Messenger Environment Variables
# Copy this file to .env and fill in your actual values

# Application
NODE_ENV=development
PORT=5000

# MongoDB Connection (Railway will provide this automatically)
# For Railway: Use the DATABASE_URL variable that Railway provides
# For local development: Use your local MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/fegr-messenger
DATABASE_URL=mongodb://localhost:27017/fegr-messenger

# JWT Secret (Generate a strong secret for production!)
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production

# Email Configuration (for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Railway specific (these will be set automatically by Railway)
# RAILWAY_STATIC_URL=https://your-app-name.up.railway.app
# RAILWAY_ENVIRONMENT=production

# Optional: Custom domain (set this in Railway dashboard)
# CUSTOM_DOMAIN=fegrem.ru

# Notes:
# 1. For Railway deployment, you only need to set:
#    - JWT_SECRET (generate a strong secret)
#    - SMTP settings (for email verification)
# 2. MongoDB URI will be provided by Railway automatically
# 3. PORT will be set by Railway automatically
# 4. For production, always use strong secrets and secure email settings